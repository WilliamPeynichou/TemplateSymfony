{% extends 'layout/app.html.twig' %}
{% block title %}Organisations{% endblock %}
{% block content %}
<div class="tactical-page-header">
    <h1 class="tactical-page-header__title">Mes <em>organisations</em></h1>
    <a href="{{ path('app_organization_new') }}" class="tactical-btn tactical-btn--primary">+ Nouvelle organisation</a>
</div>
<div class="tactical-page-body">
    {% if organizations|length == 0 %}
        <div class="tactical-card tactical-card--empty">
            <p style="color:var(--on-surface-variant);">Aucune organisation. Créez la première.</p>
            <a href="{{ path('app_organization_new') }}" class="tactical-btn tactical-btn--ghost">Créer</a>
        </div>
    {% else %}
        <div class="tactical-card-grid">
            {% for org in organizations %}
                <div class="tactical-card">
                    <div class="tactical-card__title">
                        <a href="{{ path('app_organization_show', {id: org.id}) }}" style="color:inherit;text-decoration:none;">{{ org.name }}</a>
                    </div>
                    {% if org.owner.id == app.user.id %}
                        <span class="tactical-badge tactical-badge--lime">Owner</span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
