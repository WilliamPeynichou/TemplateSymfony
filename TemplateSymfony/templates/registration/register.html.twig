{% extends 'base.html.twig' %}
{% block title %}Créer un compte{% endblock %}

{% block javascripts %}{{ importmap('app') }}{% endblock %}

{% block body %}
<div class="tactical-auth-page">
    <a href="{{ path('app_home') }}" class="tactical-auth-logo" title="Retour à l'accueil">And<span style="color:var(--secondary-container)">field</span></a>
    <div class="tactical-auth-panel tactical-auth-panel--left grain-overlay">
        <div class="tactical-auth-brand">
            Votre <em>terrain</em>, vos règles.
        </div>
        <p class="tactical-auth-tagline">
            Créez votre espace coach en moins d'une minute. Gérez vos équipes, composez votre effectif, donnez vos consignes tactiques.
        </p>
    </div>
    <div class="tactical-auth-panel tactical-auth-panel--right">
        <h1 class="tactical-auth-form-title">Créer un compte</h1>
        <p class="tactical-auth-form-sub">Rejoignez Andfield gratuitement.</p>

        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.firstName) }}</label>
                    {{ form_widget(form.firstName, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.firstName) }}</div>
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.lastName) }}</label>
                    {{ form_widget(form.lastName, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.lastName) }}</div>
                </div>
            </div>
            <div class="tactical-form-group">
                <label class="tactical-form-label">{{ form_label(form.email) }}</label>
                {{ form_widget(form.email, {attr: {class: 'tactical-input'}}) }}
                <div class="tactical-form-error">{{ form_errors(form.email) }}</div>
            </div>
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.plainPassword.first) }}</label>
                    {{ form_widget(form.plainPassword.first, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.plainPassword.first) }}</div>
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.plainPassword.second) }}</label>
                    {{ form_widget(form.plainPassword.second, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.plainPassword) }}</div>
                </div>
            </div>
            <button class="tactical-btn tactical-btn--primary" type="submit" style="width:100%;justify-content:center;">
                Créer mon compte
            </button>
        {{ form_end(form) }}

        <p style="margin-top:2rem;font-size:var(--text-label-bold);color:var(--on-surface-variant);">
            Déjà un compte ?
            <a href="{{ path('app_login') }}" class="tactical-auth-link">Se connecter</a>
        </p>
    </div>
</div>
{% endblock %}
