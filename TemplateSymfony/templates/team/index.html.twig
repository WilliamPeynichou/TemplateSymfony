{% extends 'layout/app.html.twig' %}
{% block title %}Mes équipes{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-header__title">Mes <em>équipes</em></h1>
        <p class="page-header__sub">{{ teams|length }} équipe{{ teams|length > 1 ? 's' : '' }} dans votre espace</p>
    </div>
    <a href="{{ path('app_team_new') }}" class="btn btn--filled">+ Nouvelle équipe</a>
</div>

<div class="page-body">
    {% if teams|length == 0 %}
        <div class="card-grid">
            <div class="card card--empty">
                <span style="font-size:2.5rem;">⚽</span>
                <p style="font-size:var(--text-sm);color:var(--stone-600);max-width:30ch;">
                    Vous n'avez pas encore d'équipe. Créez votre première équipe pour commencer.
                </p>
                <a href="{{ path('app_team_new') }}" class="btn">Créer une équipe</a>
            </div>
        </div>
    {% else %}
        <div class="card-grid">
            {% for team in teams %}
                <div class="card">
                    <div class="card__title">{{ team.name }}</div>
                    <div class="card__sub">
                        {% if team.club %}{{ team.club }}{% endif %}
                        {% if team.season %} · {{ team.season }}{% endif %}
                        <br>
                        <span style="color:var(--brand)">{{ team.players|length }} joueur{{ team.players|length > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="card__actions">
                        <a href="{{ path('app_composition_index', {id: team.id}) }}" class="btn btn--filled btn--sm">
                            ⚽ Composition
                        </a>
                        <a href="{{ path('app_player_index', {teamId: team.id}) }}" class="btn btn--sm">
                            Effectif
                        </a>
                        <a href="{{ path('app_team_edit', {id: team.id}) }}" class="btn btn--sm">
                            Modifier
                        </a>
                        <form method="post" action="{{ path('app_team_delete', {id: team.id}) }}"
                              onsubmit="return confirm('Supprimer cette équipe ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_team_' ~ team.id) }}">
                            <button type="submit" class="btn btn--sm btn--danger">Supprimer</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
            <div class="card card--empty">
                <span style="font-size:2rem;color:var(--stone-400)">+</span>
                <a href="{{ path('app_team_new') }}" class="btn btn--sm">Ajouter une équipe</a>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
