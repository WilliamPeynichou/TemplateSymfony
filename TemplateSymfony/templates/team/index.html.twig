{% extends 'layout/app.html.twig' %}
{% block title %}Mes équipes{% endblock %}

{% block content %}
<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title">Mes <em>équipes</em></h1>
        <p class="tactical-page-header__sub">{{ teams|length }} équipe{{ teams|length > 1 ? 's' : '' }} dans votre espace</p>
    </div>
    <a href="{{ path('app_team_new') }}" class="tactical-btn tactical-btn--primary">+ Nouvelle équipe</a>
</div>

<div class="tactical-page-body">
    {% if teams|length == 0 %}
        <div class="tactical-card-grid">
            <div class="tactical-card tactical-card--empty">
                <p style="font-size:var(--text-label-bold);color:var(--on-surface-variant);max-width:30ch;">
                    Vous n'avez pas encore d'équipe. Créez votre première équipe pour commencer.
                </p>
                <a href="{{ path('app_team_new') }}" class="tactical-btn tactical-btn--ghost">Créer une équipe</a>
            </div>
        </div>
    {% else %}
        <div class="tactical-card-grid">
            {% for team in teams %}
                <div class="tactical-card">
                    <div class="tactical-card__title">{{ team.name }}</div>
                    <div class="tactical-card__sub">
                        {% if team.club %}{{ team.club }}{% endif %}
                        {% if team.season %} · {{ team.season }}{% endif %}
                        <br>
                        <span style="color:var(--secondary-container)">{{ team.players|length }} joueur{{ team.players|length > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="tactical-card__actions">
                        <a href="{{ path('app_squad_index', {teamId: team.id}) }}" class="tactical-btn tactical-btn--primary tactical-btn--sm">
                            Vue FM
                        </a>
                        <a href="{{ path('app_strategy_index', {teamId: team.id}) }}" class="tactical-btn tactical-btn--outline tactical-btn--sm">
                            Stratégies
                        </a>
                        <a href="{{ path('app_composition_index', {id: team.id}) }}" class="tactical-btn tactical-btn--outline tactical-btn--sm">
                            Composition
                        </a>
                        <a href="{{ path('app_player_index', {teamId: team.id}) }}" class="tactical-btn tactical-btn--outline tactical-btn--sm">
                            Effectif
                        </a>
                        <a href="{{ path('app_team_calendar', {id: team.id}) }}" class="tactical-btn tactical-btn--outline tactical-btn--sm">
                            Calendrier
                        </a>
                        <a href="{{ path('app_team_attendance_summary', {id: team.id}) }}" class="tactical-btn tactical-btn--outline tactical-btn--sm">
                            Présences
                        </a>
                        <a href="{{ path('app_team_edit', {id: team.id}) }}" class="tactical-btn tactical-btn--outline tactical-btn--sm">
                            Modifier
                        </a>
                        <form method="post" action="{{ path('app_team_delete', {id: team.id}) }}"
                              onsubmit="return confirm('Supprimer cette équipe ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_team_' ~ team.id) }}">
                            <button type="submit" class="tactical-btn tactical-btn--danger tactical-btn--sm">Supprimer</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
            <div class="tactical-card tactical-card--empty">
                <span style="font-size:2rem;color:var(--on-surface-variant)">+</span>
                <a href="{{ path('app_team_new') }}" class="tactical-btn tactical-btn--ghost tactical-btn--sm">Ajouter une équipe</a>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
