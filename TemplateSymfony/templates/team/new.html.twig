{% extends 'layout/app.html.twig' %}
{% block title %}Nouvelle équipe{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-header__title">Nouvelle <em>équipe</em></h1>
        <p class="page-header__sub">Ajoutez une équipe à votre espace</p>
    </div>
    <a href="{{ path('app_team_index') }}" class="btn">← Retour</a>
</div>
<div class="page-body">
    <div class="form-card">
        {{ form_start(form) }}
            <div class="form-group">
                <label class="form-label">{{ form_label(form.name) }}</label>
                {{ form_widget(form.name, {attr: {class: 'form-control'}}) }}
                <div class="form-error">{{ form_errors(form.name) }}</div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">{{ form_label(form.club) }}</label>
                    {{ form_widget(form.club, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="form-group">
                    <label class="form-label">{{ form_label(form.season) }}</label>
                    {{ form_widget(form.season, {attr: {class: 'form-control'}}) }}
                </div>
            </div>
            <div class="form-actions">
                <button class="btn btn--filled" type="submit">Créer l'équipe</button>
                <a href="{{ path('app_team_index') }}" class="btn">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
