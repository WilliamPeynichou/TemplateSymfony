{% extends 'layout/app.html.twig' %}
{% block title %}Modifier {{ team.name }}{% endblock %}

{% block content %}
<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title">Modifier <em>{{ team.name }}</em></h1>
    </div>
    <a href="{{ path('app_team_index') }}" class="tactical-btn tactical-btn--outline">← Retour</a>
</div>
<div class="tactical-page-body">
    <div class="tactical-form-card">
        {{ form_start(form) }}
            <div class="tactical-form-group">
                <label class="tactical-form-label">{{ form_label(form.name) }}</label>
                {{ form_widget(form.name, {attr: {class: 'tactical-input'}}) }}
                <div class="tactical-form-error">{{ form_errors(form.name) }}</div>
            </div>
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.club) }}</label>
                    {{ form_widget(form.club, {attr: {class: 'tactical-input'}}) }}
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.season) }}</label>
                    {{ form_widget(form.season, {attr: {class: 'tactical-input'}}) }}
                </div>
            </div>
            <div class="tactical-form-actions">
                <button class="tactical-btn tactical-btn--primary" type="submit">Enregistrer</button>
                <a href="{{ path('app_team_index') }}" class="tactical-btn tactical-btn--outline">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
