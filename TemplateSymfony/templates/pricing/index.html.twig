{% extends 'base.html.twig' %}

{% block title %}Andfield — Tarifs{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
{% endblock %}

{% block body %}
<nav class="tactical-nav" id="tactical-nav">
    <a href="{{ path('app_home') }}" class="tactical-nav__logo">Andfield</a>
    <ul class="tactical-nav__links">
        <li><a href="{{ path('app_home') }}">Accueil</a></li>
        <li><a href="{{ path('app_home') }}#fonctionnalites">Fonctionnalités</a></li>
        <li><a href="{{ path('app_home') }}#faq">FAQ</a></li>
    </ul>
    <a href="{{ path('app_login') }}" class="tactical-btn tactical-btn--primary">Se connecter</a>
</nav>

<main style="padding-top:6rem;">
    <div class="container" style="padding-top:3rem;padding-bottom:5rem;">
        <div style="text-align:center;margin-bottom:3.5rem;">
            <span class="tactical-section-label">Tarifs</span>
            <h1 style="font-family:var(--font-display);font-size:clamp(2.2rem,5vw,3.5rem);margin:0.75rem 0 1rem;">
                Un tarif <em>honnête</em> pour chaque coach
            </h1>
            <p style="color:var(--on-surface-variant);max-width:640px;margin:0 auto;font-size:1.0625rem;">
                Commencez gratuitement. Passez à un plan payant quand votre club grandit.
                Sans engagement, annulation en un clic.
            </p>
        </div>

        <div class="tactical-plans-grid">
            {% for plan in plans %}
                <article class="tactical-plan-card {% if plan.highlighted %}tactical-plan-card--featured{% endif %}" data-plan="{{ plan.id }}">
                    {% if plan.highlighted %}
                        <span class="tactical-plan-card__flag">Recommandé</span>
                    {% endif %}
                    <header>
                        <h3>{{ plan.name }}</h3>
                        <span class="tactical-plan-card__price">{{ plan.price }}<span>{{ plan.period }}</span></span>
                    </header>
                    <p style="color:var(--on-surface-variant);font-size:0.9375rem;min-height:2.5em;">{{ plan.description }}</p>
                    <ul>
                        {% for feature in plan.features %}
                            <li>{{ feature }}</li>
                        {% endfor %}
                    </ul>
                    <a href="{{ path('app_register', {plan: plan.id}) }}"
                       class="tactical-btn {% if plan.highlighted %}tactical-btn--primary{% else %}tactical-btn--ghost{% endif %}"
                       style="margin-top:auto;text-align:center;">
                        {{ plan.cta }}
                    </a>
                </article>
            {% endfor %}
        </div>

        <p style="text-align:center;color:var(--on-surface-variant);margin-top:3rem;font-size:0.875rem;">
            Les tarifs en euros incluent la TVA. Paiement sécurisé via Stripe.
        </p>
    </div>
</main>

<footer class="tactical-footer">
    <div class="container tactical-footer__bottom">
        <span class="tactical-footer__copy">© {{ "now"|date("Y") }} Andfield. Tous droits réservés.</span>
    </div>
</footer>
{% endblock %}
