{% extends 'layout/app.html.twig' %}
{% block title %}Plans — {{ team.name }}{% endblock %}

{% block content %}
<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title">Plans <em>{{ team.name }}</em></h1>
        <p class="tactical-page-header__sub">{{ plans|length }} plan{{ plans|length > 1 ? 's' : '' }} de coaching</p>
    </div>
    <div style="display:flex;gap:1rem;">
        <a href="{{ path('app_composition_index', {id: team.id}) }}" class="tactical-btn tactical-btn--outline">Composition</a>
    </div>
</div>

<div class="tactical-page-body">
    {# Nouveau plan #}
    <div class="tactical-card" style="margin-bottom:var(--space-md);">
        <form method="post" action="{{ path('app_plan_new', {teamId: team.id}) }}" style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap;">
            <div class="tactical-form-group" style="flex:1;min-width:200px;margin:0;">
                <label class="tactical-form-label">Nom du plan</label>
                <input type="text" name="name" class="tactical-input" placeholder="Ex: Plan A · Pressing haut · 4-3-3" required style="width:100%;">
            </div>
            <div class="tactical-form-group" style="flex:2;min-width:200px;margin:0;">
                <label class="tactical-form-label">Description (optionnel)</label>
                <input type="text" name="description" class="tactical-input" placeholder="Ex: Bloc médian, transitions rapides…" style="width:100%;">
            </div>
            <button type="submit" class="tactical-btn tactical-btn--primary">+ Créer le plan</button>
        </form>
    </div>

    {% if plans|length == 0 %}
        <div class="tactical-card-grid">
            <div class="tactical-card tactical-card--empty">
                <p style="font-size:0.875rem;color:var(--on-surface-variant);max-width:32ch;">
                    Aucun plan de coaching. Créez votre premier plan pour commencer à organiser votre jeu.
                </p>
            </div>
        </div>
    {% else %}
        <div class="tactical-card-grid">
            {% for plan in plans %}
                <div class="tactical-card" style="padding:0;overflow:hidden;">
                    <a href="{{ path('app_plan_canvas', {teamId: team.id, id: plan.id}) }}"
                       style="display:block;padding:var(--space-md) var(--space-md) var(--space-sm);text-decoration:none;color:inherit;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.5rem;">
                            <span style="font-family:var(--font-display);font-size:1.125rem;color:var(--on-surface);">{{ plan.name }}</span>
                            <span style="font-size:0.75rem;color:var(--on-surface-variant);white-space:nowrap;margin-top:0.3rem;">{{ plan.updatedAt|date('d/m/Y') }}</span>
                        </div>
                        {% if plan.description %}
                            <p style="font-size:0.875rem;color:var(--on-surface-variant);line-height:1.5;margin:0 0 0.75rem;">{{ plan.description }}</p>
                        {% endif %}
                        <div style="display:flex;align-items:center;gap:0.5rem;">
                            <span class="tactical-badge tactical-badge--lime">{{ plan.notes|length }} joueur{{ plan.notes|length > 1 ? 's' : '' }}</span>
                            <span style="font-size:0.75rem;color:var(--secondary-container);font-weight:500;">Ouvrir →</span>
                        </div>
                    </a>
                    <div style="border-top:1px solid var(--outline-variant);padding:0.75rem var(--space-md);background:var(--surface-container-lowest);display:flex;justify-content:flex-end;">
                        <form method="post" action="{{ path('app_plan_delete', {teamId: team.id, id: plan.id}) }}"
                              onsubmit="return confirm('Supprimer « {{ plan.name }} » ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_plan_' ~ plan.id) }}">
                            <button type="submit" class="tactical-btn tactical-btn--sm tactical-btn--danger">Supprimer</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
