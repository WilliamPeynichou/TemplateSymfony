{% extends 'base.html.twig' %}
{% block title %}Composition — {{ team.name }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/composition.css') }}">
{% endblock %}

{% block javascripts %}
    {{ importmap('app') }}
    {{ importmap('composition') }}
{% endblock %}

{% block body %}
<div
    data-controller="pitch sidebar"
    data-pitch-save-url-value="{{ path('app_composition_save', {id: team.id}) }}"
    data-pitch-team-id-value="{{ team.id }}"
    data-action="composition:updateInstructions->pitch#updateInstructionsFromEvent composition:removePlayer->pitch#removePlayerFromEvent pitch:playerSelected->sidebar#open"
    class="tactical-composition-layout"
>
    {# ── Zone terrain ──────────────────────────────────────── #}
    <div class="tactical-pitch-area">
        <div class="tactical-pitch-toolbar">
            <div class="tactical-pitch-toolbar__left">
                <a href="{{ path('app_team_index') }}" class="tactical-pitch-back" title="Retour aux équipes">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                </a>
                <div>
                    <div class="tactical-pitch-toolbar__title"><em>{{ team.name }}</em></div>
                    {% if team.club or team.season %}
                        <div class="tactical-pitch-toolbar__sub">{{ team.club }}{% if team.club and team.season %} · {% endif %}{{ team.season }}</div>
                    {% endif %}
                </div>
            </div>
            <div class="tactical-pitch-toolbar__actions">
                <span class="tactical-save-indicator" data-pitch-target="saveIndicator"></span>
                <a href="{{ path('app_strategy_index', {teamId: team.id}) }}" class="tactical-btn tactical-btn--sm tactical-btn--outline">Plans tactiques</a>
                <a href="{{ path('app_player_index', {teamId: team.id}) }}" class="tactical-btn tactical-btn--sm tactical-btn--outline">Effectif</a>
            </div>
        </div>

        <div class="tactical-pitch-container">
            <div class="tactical-pitch-wrapper" data-pitch-target="wrapper">
                {# ── Terrain SVG (Tactical Elite colors) ──────────────────────────────── #}
                <svg class="tactical-pitch-svg" viewBox="0 0 68 105" xmlns="http://www.w3.org/2000/svg">
                    <rect width="68" height="105" fill="#101415"/>
                    {% for i in 0..6 %}
                        <rect x="0" y="{{ i * 15 }}" width="68" height="7.5" fill="{{ i % 2 == 0 ? '#101415' : 'rgba(255,255,255,0.03)' }}"/>
                    {% endfor %}
                    <rect x="1" y="1" width="66" height="103" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <line x1="1" y1="52.5" x2="67" y2="52.5" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <circle cx="34" cy="52.5" r="9.15" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <circle cx="34" cy="52.5" r="0.7" fill="#c7f300"/>
                    <rect x="13.84" y="1" width="40.32" height="16.5" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <rect x="24.84" y="1" width="18.32" height="5.5" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <rect x="29.3" y="0" width="9.4" height="1" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <circle cx="34" cy="12" r="0.5" fill="rgba(199,243,0,0.4)"/>
                    <path d="M 20.16 17.5 A 9.15 9.15 0 0 1 47.84 17.5" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <rect x="13.84" y="87.5" width="40.32" height="16.5" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <rect x="24.84" y="98.5" width="18.32" height="5.5" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <rect x="29.3" y="104" width="9.4" height="1" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <circle cx="34" cy="93" r="0.5" fill="rgba(199,243,0,0.4)"/>
                    <path d="M 20.16 87.5 A 9.15 9.15 0 0 0 47.84 87.5" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <path d="M 1 3.5 A 2.5 2.5 0 0 0 3.5 1" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <path d="M 64.5 1 A 2.5 2.5 0 0 0 67 3.5" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <path d="M 1 101.5 A 2.5 2.5 0 0 1 3.5 104" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                    <path d="M 64.5 104 A 2.5 2.5 0 0 1 67 101.5" fill="none" stroke="rgba(199,243,0,0.25)" stroke-width="0.5"/>
                </svg>

                {# ── Joueurs placés ────────────────────────────── #}
                <div class="tactical-pitch-players" data-pitch-target="players">
                    {% for playerId, pos in positions %}
                        {% set player = null %}
                        {% for p in players %}
                            {% if p.id == playerId %}{% set player = p %}{% endif %}
                        {% endfor %}
                        {% if player %}
                            <div class="tactical-player-token"
                                 data-player-id="{{ player.id }}"
                                 data-player-data="{{ {
                                     id: player.id,
                                     firstName: player.firstName,
                                     lastName: player.lastName,
                                     number: player.number,
                                     position: player.position,
                                     photo: player.photo,
                                     age: player.age,
                                     strongFoot: player.strongFoot,
                                     height: player.height,
                                     weight: player.weight
                                 }|json_encode }}"
                                 data-instructions="{{ pos.instructions }}"
                                 draggable="true"
                                 style="left:{{ pos.posX }}%;top:{{ pos.posY }}%">
                                <div class="tactical-player-token__circle">{{ player.number }}</div>
                                <div class="tactical-player-token__name">{{ player.lastName }}</div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# ── Panneau droit ─────────────────────────────────────── #}
    <div class="tactical-right-panel" data-sidebar-target="panel">

        {# ── Onglets ─────────────────────────────────────────── #}
        <div class="tactical-panel-tabs">
            <button class="tactical-panel-tab tactical-panel-tab--active" data-sidebar-target="benchTab" data-action="click->sidebar#showBench">
                Disponibles
                <span class="tactical-panel-tab__badge" data-sidebar-target="benchCount">{{ benchPlayers|length }}</span>
            </button>
            <button class="tactical-panel-tab tactical-panel-tab--player" data-sidebar-target="playerTab">
                <span data-sidebar-target="playerTabLabel">Joueur</span>
                <span class="tactical-panel-tab__close" data-action="click->sidebar#close">×</span>
            </button>
        </div>

        {# ── Panel effectif (bench) ───────────────────────────── #}
        <div class="tactical-panel-section tactical-panel-section--bench" data-sidebar-target="benchPanel">

            {# Filtres poste #}
            <div class="tactical-pos-filters">
                <button class="tactical-pos-filter tactical-pos-filter--active" data-action="click->sidebar#filterBench" data-filter="all">Tous</button>
                <button class="tactical-pos-filter" data-action="click->sidebar#filterBench" data-filter="GK">GK</button>
                <button class="tactical-pos-filter" data-action="click->sidebar#filterBench" data-filter="DEF">Déf</button>
                <button class="tactical-pos-filter" data-action="click->sidebar#filterBench" data-filter="MIL">Mil</button>
                <button class="tactical-pos-filter" data-action="click->sidebar#filterBench" data-filter="ATT">Att</button>
            </div>

            {# Liste joueurs #}
            <div class="tactical-bench-scroll">
                <div class="tactical-bench-list" data-pitch-target="bench">
                    {% for player in benchPlayers %}
                        {% set posGroup = player.position == 'GK' ? 'GK' : (player.position in ['CB','LB','RB'] ? 'DEF' : (player.position in ['CDM','CM','CAM'] ? 'MIL' : 'ATT')) %}
                        <div class="tactical-bench-card"
                             draggable="true"
                             data-player-id="{{ player.id }}"
                             data-pos-group="{{ posGroup }}"
                             data-player-data="{{ {
                                 id:         player.id,
                                 firstName:  player.firstName,
                                 lastName:   player.lastName,
                                 number:     player.number,
                                 position:   player.position,
                                 photo:      player.photo,
                                 age:        player.age,
                                 strongFoot: player.strongFoot,
                                 height:     player.height,
                                 weight:     player.weight
                             }|json_encode }}">
                            {% if player.photo %}
                                <img src="/uploads/players/{{ player.photo }}" class="tactical-bench-card__photo" alt="">
                            {% else %}
                                <div class="tactical-bench-card__avatar tactical-bench-card__avatar--{{ posGroup|lower }}">{{ player.firstName|slice(0,1) }}{{ player.lastName|slice(0,1) }}</div>
                            {% endif %}
                            <div class="tactical-bench-card__info">
                                <div class="tactical-bench-card__name">{{ player.lastName }}</div>
                                <div class="tactical-bench-card__meta">
                                    <span class="tactical-bench-card__num">#{{ player.number }}</span>
                                    <span class="tactical-chip-pos tactical-chip-pos--{{ posGroup|lower }}">{{ player.position }}</span>
                                </div>
                            </div>
                            <div class="tactical-bench-card__drag">⣿</div>
                        </div>
                    {% endfor %}
                </div>
                {% if benchPlayers|length == 0 %}
                    <div class="tactical-bench-all-placed">
                        <span style="font-size:1.5rem;">✓</span>
                        <span>Tous les joueurs sont sur le terrain</span>
                    </div>
                {% endif %}
            </div>
        </div>

        {# ── Panel fiche joueur ───────────────────────────────── #}
        <div class="tactical-panel-section tactical-panel-section--player" data-sidebar-target="playerPanel">

            <div class="tactical-fiche-header" data-sidebar-target="header">
                <div class="tactical-fiche-player-row">
                    <div class="tactical-fiche-avatar" data-sidebar-target="avatar"></div>
                    <div class="tactical-fiche-player-details">
                        <div class="tactical-fiche-name" data-sidebar-target="name"></div>
                        <div class="tactical-fiche-badges">
                            <span class="tactical-badge tactical-badge--lime" data-sidebar-target="number"></span>
                            <span class="tactical-badge" data-sidebar-target="position"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tactical-fiche-body" data-sidebar-target="body">
                <div class="tactical-fiche-stats">
                    <div class="tactical-fiche-stat">
                        <span class="tactical-fiche-stat__label">Âge</span>
                        <span class="tactical-fiche-stat__value" data-sidebar-target="age">—</span>
                    </div>
                    <div class="tactical-fiche-stat">
                        <span class="tactical-fiche-stat__label">Pied</span>
                        <span class="tactical-fiche-stat__value" data-sidebar-target="foot">—</span>
                    </div>
                    <div class="tactical-fiche-stat">
                        <span class="tactical-fiche-stat__label">Taille</span>
                        <span class="tactical-fiche-stat__value" data-sidebar-target="height">—</span>
                    </div>
                    <div class="tactical-fiche-stat">
                        <span class="tactical-fiche-stat__label">Poids</span>
                        <span class="tactical-fiche-stat__value" data-sidebar-target="weight">—</span>
                    </div>
                </div>

                <div class="tactical-fiche-instructions-section">
                    <span class="tactical-fiche-label">Instructions tactiques</span>
                    <textarea class="tactical-instructions-textarea"
                              data-sidebar-target="instructions"
                              data-action="blur->sidebar#saveInstructions"
                              placeholder="Ex: Presse haut dès la perte de balle, couvre le couloir gauche en phase défensive…"></textarea>
                </div>
            </div>

            <div class="tactical-fiche-footer" data-sidebar-target="footer">
                <button class="tactical-btn tactical-btn--sm tactical-btn--primary" data-action="sidebar#saveInstructions" style="flex:1;">
                    Sauvegarder
                </button>
                <button class="tactical-btn tactical-btn--sm tactical-btn--danger" data-action="sidebar#removePlayer">Retirer</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
