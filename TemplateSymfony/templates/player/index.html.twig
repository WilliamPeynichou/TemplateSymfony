{% extends 'layout/app.html.twig' %}
{% block title %}Effectif — {{ team.name }}{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-header__title">Effectif <em>{{ team.name }}</em></h1>
        <p class="page-header__sub">{{ players|length }} joueur{{ players|length > 1 ? 's' : '' }}</p>
    </div>
    <div style="display:flex;gap:1rem;">
        <a href="{{ path('app_composition_index', {id: team.id}) }}" class="btn">⚽ Composition</a>
        <a href="{{ path('app_player_new', {teamId: team.id}) }}" class="btn btn--filled">+ Joueur</a>
    </div>
</div>

<div class="page-body">
    {% if players|length == 0 %}
        <div class="card-grid">
            <div class="card card--empty">
                <span style="font-size:2.5rem;">👤</span>
                <p style="font-size:var(--text-sm);color:var(--stone-600);max-width:30ch;">
                    Aucun joueur dans cet effectif. Ajoutez vos premiers joueurs.
                </p>
                <a href="{{ path('app_player_new', {teamId: team.id}) }}" class="btn">Ajouter un joueur</a>
            </div>
        </div>
    {% else %}
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Joueur</th>
                        <th>Poste</th>
                        <th>Âge</th>
                        <th>Pied</th>
                        <th>Taille</th>
                        <th>Poids</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for player in players %}
                        <tr>
                            <td>
                                <span class="badge badge--brand">{{ player.number }}</span>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:0.75rem;">
                                    {% if player.photo %}
                                        <img src="/uploads/players/{{ player.photo }}" alt=""
                                             style="width:32px;height:32px;object-fit:cover;border-radius:50%;">
                                    {% else %}
                                        <div style="width:32px;height:32px;background:var(--hazel-green-200);display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:var(--brand-dark);font-weight:500;">
                                            {{ player.firstName|slice(0,1) }}{{ player.lastName|slice(0,1) }}
                                        </div>
                                    {% endif %}
                                    <strong style="font-weight:500;">{{ player.fullName }}</strong>
                                </div>
                            </td>
                            <td><span class="badge">{{ player.position }}</span></td>
                            <td>{{ player.age ? player.age ~ ' ans' : '—' }}</td>
                            <td>
                                {% if player.strongFoot == 'right' %}D
                                {% elseif player.strongFoot == 'left' %}G
                                {% elseif player.strongFoot == 'both' %}D/G
                                {% else %}—{% endif %}
                            </td>
                            <td>{{ player.height ? player.height ~ ' cm' : '—' }}</td>
                            <td>{{ player.weight ? player.weight ~ ' kg' : '—' }}</td>
                            <td>
                                <div style="display:flex;gap:0.5rem;">
                                    <a href="{{ path('app_player_edit', {teamId: team.id, id: player.id}) }}" class="btn btn--sm">Modifier</a>
                                    <form method="post" action="{{ path('app_player_delete', {teamId: team.id, id: player.id}) }}"
                                          onsubmit="return confirm('Supprimer {{ player.fullName }} ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_player_' ~ player.id) }}">
                                        <button type="submit" class="btn btn--sm btn--danger">×</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
