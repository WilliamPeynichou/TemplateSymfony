{% extends 'layout/app.html.twig' %}
{% block title %}Modifier {{ player.fullName }}{% endblock %}

{% block content %}
<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title">Modifier <em>{{ player.fullName }}</em></h1>
        <p class="tactical-page-header__sub">{{ team.name }}</p>
    </div>
    <a href="{{ path('app_player_show', {teamId: team.id, id: player.id}) }}" class="tactical-btn tactical-btn--outline">← Fiche</a>
</div>
<div class="tactical-page-body">
    <div class="tactical-form-card" style="max-width:760px;">
        {{ form_start(form, {attr: {enctype: 'multipart/form-data'}}) }}
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.firstName) }}</label>
                    {{ form_widget(form.firstName, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.firstName) }}</div>
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.lastName) }}</label>
                    {{ form_widget(form.lastName, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.lastName) }}</div>
                </div>
            </div>
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.number) }}</label>
                    {{ form_widget(form.number, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.number) }}</div>
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.position) }}</label>
                    {{ form_widget(form.position, {attr: {class: 'tactical-input'}}) }}
                </div>
            </div>
            <div class="tactical-form-group">
                <label class="tactical-form-label">{{ form_label(form.licenseNumber) }}</label>
                {{ form_widget(form.licenseNumber, {attr: {class: 'tactical-input'}}) }}
                <div class="tactical-form-error">{{ form_errors(form.licenseNumber) }}</div>
            </div>
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.status) }}</label>
                    {{ form_widget(form.status, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.status) }}</div>
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.statusReason) }}</label>
                    {{ form_widget(form.statusReason, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.statusReason) }}</div>
                </div>
            </div>
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.email) }}</label>
                    {{ form_widget(form.email, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.email) }}</div>
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.phone) }}</label>
                    {{ form_widget(form.phone, {attr: {class: 'tactical-input'}}) }}
                    <div class="tactical-form-error">{{ form_errors(form.phone) }}</div>
                </div>
            </div>
            <div class="tactical-form-group">
                <label class="tactical-form-label">{{ form_label(form.emergencyContact) }}</label>
                {{ form_widget(form.emergencyContact, {attr: {class: 'tactical-input'}}) }}
                <div class="tactical-form-error">{{ form_errors(form.emergencyContact) }}</div>
            </div>
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.dateOfBirth) }}</label>
                    {{ form_widget(form.dateOfBirth, {attr: {class: 'tactical-input'}}) }}
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.strongFoot) }}</label>
                    {{ form_widget(form.strongFoot, {attr: {class: 'tactical-input'}}) }}
                </div>
            </div>
            <div class="tactical-form-row">
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.height) }}</label>
                    {{ form_widget(form.height, {attr: {class: 'tactical-input'}}) }}
                </div>
                <div class="tactical-form-group">
                    <label class="tactical-form-label">{{ form_label(form.weight) }}</label>
                    {{ form_widget(form.weight, {attr: {class: 'tactical-input'}}) }}
                </div>
            </div>
            {% if player.photo %}
                <div class="tactical-form-group">
                    <label class="tactical-form-label">Photo actuelle</label>
                    <img src="/uploads/players/{{ player.photo }}" alt=""
                         style="width:80px;height:80px;object-fit:cover;display:block;border-radius:var(--radius);margin-bottom:0.75rem;border:1px solid var(--outline-variant);">
                </div>
            {% endif %}
            <div class="tactical-form-group">
                <label class="tactical-form-label">{{ form_label(form.photoFile) }}</label>
                {{ form_widget(form.photoFile) }}
                <div class="tactical-form-error">{{ form_errors(form.photoFile) }}</div>
            </div>
            <div class="tactical-form-actions">
                <button class="tactical-btn tactical-btn--primary" type="submit">Enregistrer</button>
                <a href="{{ path('app_player_show', {teamId: team.id, id: player.id}) }}" class="tactical-btn tactical-btn--outline">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>

    <div class="tactical-form-card" style="max-width:760px;margin-top:1.5rem;">
        <h2 class="tactical-card__title">Historique du statut</h2>
        {% if statusHistory|length == 0 %}
            <p class="tactical-card__sub">Aucun changement de statut enregistré.</p>
        {% else %}
            <div class="tactical-table-wrap">
                <table class="tactical-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Changement</th>
                            <th>Motif</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in statusHistory %}
                            <tr>
                                <td>{{ item.changedAt|date('d/m/Y H:i') }}</td>
                                <td>{{ item.oldStatusLabel }} → {{ item.newStatusLabel }}</td>
                                <td>{{ item.reason ?: '—' }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    <div class="tactical-form-card danger-zone">
        <h2 class="tactical-card__title">Zone sensible</h2>
        <p class="tactical-card__sub">La suppression d'un joueur est séparée de la modification pour éviter les erreurs de manipulation.</p>
        <form method="post" action="{{ path('app_player_delete', {teamId: team.id, id: player.id}) }}"
              onsubmit="return confirm('Supprimer définitivement {{ player.fullName }} ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_player_' ~ player.id) }}">
            <button type="submit" class="tactical-btn tactical-btn--danger">Supprimer le joueur</button>
        </form>
    </div>
</div>
{% endblock %}
