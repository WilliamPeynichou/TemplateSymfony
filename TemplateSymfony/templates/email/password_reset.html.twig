{% extends 'email/_layout.html.twig' %}

{% block subject %}Réinitialisation de votre mot de passe Andfield{% endblock %}

{% block content %}
<p>Bonjour,</p>
<p>Vous avez demandé la réinitialisation de votre mot de passe. Cliquez sur le bouton ci-dessous pour en choisir un nouveau.</p>
<p>Ce lien est valable <strong>1 heure</strong>. Si vous n'êtes pas à l'origine de cette demande, vous pouvez ignorer cet email.</p>
{% endblock %}

{% block cta %}
<div class="cta-wrap">
  <a href="{{ resetLink }}" class="cta">Réinitialiser mon mot de passe</a>
</div>
<p style="font-size:12px;color:#8a876e;margin-top:8px;">
  Ou copiez ce lien : <a href="{{ resetLink }}" style="color:#8a876e;word-break:break-all;">{{ resetLink }}</a>
</p>
{% endblock %}
