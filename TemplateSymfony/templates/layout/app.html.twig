<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="theme-color" content="#101415">
        <title>{% block title %}Andfield{% endblock %} — Andfield</title>
        <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2228%22 fill=%22%23101415%22/><text x=%2264%22 y=%2296%22 text-anchor=%22middle%22 font-family=%22Lexend,Georgia,serif%22 font-size=%2296%22 font-style=%22italic%22 font-weight=%22800%22 fill=%22%23c7f300%22>A</text></svg>">
        <link rel="manifest" href="/manifest.webmanifest">
        <script>
            if ('serviceWorker' in navigator) {
                window.addEventListener('load', () => {
                    navigator.serviceWorker.register('/sw.js').catch(() => {});
                });
            }
        </script>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {{ importmap(['app', 'agent-chat']) }}
        {% endblock %}
        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
            <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
            <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
            <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
        {% set _route = app.request.attributes.get('_route') %}
        {% set _idIsTeam = _route starts with 'app_team_' or _route starts with 'app_training_' or _route starts with 'app_fixture_' or _route starts with 'app_composition_' %}
        {% set _teamRouteId = _idIsTeam ? app.request.attributes.get('id') : null %}
        {% set _fallbackTeam = app.user.teams|first %}
        {% set _teamId = app.request.attributes.get('teamId') ?: (_teamRouteId ?: (app.request.query.get('team_id') ?: (_fallbackTeam ? _fallbackTeam.id : ''))) %}
    <body data-team-id="{{ _teamId }}">
        <div class="tactical-shell">
            <aside class="tactical-sidebar">
                <a href="{{ path('app_home') }}" class="tactical-sidebar__logo" title="Retour à l'accueil">And<span>field</span></a>
                <nav class="tactical-sidebar__nav">
                    <span class="tactical-sidebar__section-label">Navigation</span>
                    <a href="{{ path('app_team_index') }}"
                       class="tactical-sidebar__link {% if app.request.attributes.get('_route') starts with 'app_team' %}tactical-sidebar__link--active{% endif %}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="0"/><path d="M8 21h8M12 17v4"/></svg>
                        Mes équipes
                    </a>
                    <a href="{{ path('app_match_prepare') }}"
                       class="tactical-sidebar__link {% if app.request.attributes.get('_route') starts with 'app_match' %}tactical-sidebar__link--active{% endif %}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 4v16"/><path d="M17 4v16"/><path d="M3 8h18"/><path d="M3 16h18"/><path d="M12 8v8"/></svg>
                        Préparer un match
                    </a>
                    {% set teamId = _teamId %}
                    <span class="tactical-sidebar__section-label" style="margin-top:1rem;">Équipe</span>
                    <a href="{{ path('app_my_strategies') }}"
                       class="tactical-sidebar__link {% if app.request.attributes.get('_route') starts with 'app_my_strategies' or app.request.attributes.get('_route') starts with 'app_strategy' or app.request.attributes.get('_route') starts with 'app_composition' %}tactical-sidebar__link--active{% endif %}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/></svg>
                        Mes tactiques
                    </a>
                    <a href="{{ teamId ? path('app_player_index', {teamId: teamId}) : path('app_team_index') }}"
                       class="tactical-sidebar__link {% if app.request.attributes.get('_route') starts with 'app_player' %}tactical-sidebar__link--active{% endif %}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Effectif
                    </a>
                    <a href="{{ teamId ? path('app_team_calendar', {id: teamId}) : path('app_team_index') }}"
                       class="tactical-sidebar__link {% if app.request.attributes.get('_route') starts with 'app_team_calendar' or app.request.attributes.get('_route') starts with 'app_training' or app.request.attributes.get('_route') starts with 'app_fixture' %}tactical-sidebar__link--active{% endif %}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="0"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                        Calendrier
                    </a>
                    <a href="{{ teamId ? path('app_team_attendance_summary', {id: teamId}) : path('app_team_index') }}"
                       class="tactical-sidebar__link {% if app.request.attributes.get('_route') starts with 'app_team_attendance' %}tactical-sidebar__link--active{% endif %}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
                        Présences
                    </a>
                    <a href="{{ teamId ? path('app_team_material', {id: teamId}) : path('app_team_index') }}"
                       class="tactical-sidebar__link {% if app.request.attributes.get('_route') starts with 'app_team_material' %}tactical-sidebar__link--active{% endif %}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                        Matériel
                    </a>
                </nav>
                <div class="tactical-sidebar__footer">
                    <div class="tactical-sidebar__user">
                        <div class="tactical-sidebar__avatar">{{ app.user.firstName|slice(0,1) }}{{ app.user.lastName|slice(0,1) }}</div>
                        <div>
                            <div class="tactical-sidebar__user-name">{{ app.user.fullName }}</div>
                            <div class="tactical-sidebar__user-role">Coach</div>
                        </div>
                    </div>
                    <a href="{{ path('app_logout') }}" class="tactical-sidebar__logout">Déconnexion →</a>
                </div>
            </aside>

            <main class="tactical-main">
                <details class="tactical-mobile-nav">
                    <summary class="tactical-mobile-nav__summary">
                        <span>And<span>field</span></span>
                        <strong>Menu</strong>
                    </summary>
                    <nav class="tactical-mobile-nav__links" aria-label="Navigation mobile coach">
                        <a href="{{ path('app_team_index') }}">Équipes</a>
                        <a href="{{ teamId ? path('app_team_dashboard', {id: teamId}) : path('app_team_index') }}">Dashboard</a>
                        <a href="{{ teamId ? path('app_player_index', {teamId: teamId}) : path('app_team_index') }}">Effectif</a>
                        <a href="{{ teamId ? path('app_team_calendar', {id: teamId}) : path('app_team_index') }}">Calendrier</a>
                        <a href="{{ teamId ? path('app_team_attendance_summary', {id: teamId}) : path('app_team_index') }}">Stats</a>
                    </nav>
                </details>

                {% if app.flashes|length > 0 %}
                    <div class="tactical-flash-wrap">
                        {% for type, messages in app.flashes %}
                            {% for message in messages %}
                                <div class="tactical-flash tactical-flash--{{ type }}">{{ message }}</div>
                            {% endfor %}
                        {% endfor %}
                    </div>
                {% endif %}

                {% block content %}{% endblock %}
            </main>
        </div>
        {% include '_partials/agent_sidebar.html.twig' %}
    </body>
</html>
