{% extends 'layout/app.html.twig' %}
{% block title %}Nouvelle séance{% endblock %}
{% block content %}
    <h1>Nouvelle séance — {{ team.name }}</h1>
    <form method="post">
        <p><label>Titre <input name="title" required></label></p>
        <p><label>Début (YYYY-MM-DD HH:MM)
            <input name="starts_at" type="datetime-local" required></label></p>
        <p><label>Durée (minutes)
            <input name="duration_minutes" type="number" value="90" min="15"></label></p>
        <p><label>Lieu <input name="location"></label></p>
        <p><label>Thématique <input name="focus" placeholder="ex. placement défensif"></label></p>
        <p><label>Plan détaillé <textarea name="plan" rows="6" cols="60"></textarea></label></p>
        <button type="submit">Créer</button>
    </form>
{% endblock %}
