{% extends 'layout/app.html.twig' %}
{% block title %}Présences — {{ eventTitle }}{% endblock %}

{% block content %}
<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title">Présences <em>{{ eventType == 'fixture' ? 'match' : 'séance' }}</em></h1>
        <p class="tactical-page-header__sub">{{ eventTitle }}{% if eventSubtitle %} · {{ eventSubtitle }}{% endif %}</p>
    </div>
    <a href="{{ path('app_team_calendar', {id: team.id}) }}" class="tactical-btn tactical-btn--outline">← Calendrier</a>
</div>

<div class="tactical-page-body">
    <form method="post" class="tactical-form-card">
        <input type="hidden" name="_token" value="{{ csrf_token(csrfTokenId) }}">

        {% if players|length == 0 %}
            <p class="tactical-card__sub">Aucun joueur dans l'effectif.</p>
        {% else %}
            <div class="tactical-table-wrap">
                <table class="tactical-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Joueur</th>
                            <th>Statut joueur</th>
                            <th>Présence</th>
                            <th>Motif</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for player in players %}
                            {% set attendance = attendanceMap[player.id] ?? null %}
                            {% set selectedStatus = attendance ? attendance.status : 'present' %}
                            <tr>
                                <td><span class="tactical-badge tactical-badge--primary">{{ player.number }}</span></td>
                                <td>
                                    <strong style="font-weight:600;">{{ player.fullName }}</strong>
                                    <div style="color:var(--on-surface-variant);font-size:var(--text-label-sm);">{{ player.position }}</div>
                                </td>
                                <td>
                                    <span class="tactical-badge {{ player.status == 'present' ? 'tactical-badge--lime' : '' }}">{{ player.statusLabel }}</span>
                                    {% if player.statusReason %}
                                        <div style="margin-top:0.35rem;color:var(--on-surface-variant);font-size:var(--text-label-sm);max-width:22ch;">{{ player.statusReason }}</div>
                                    {% endif %}
                                </td>
                                <td style="min-width:190px;">
                                    <select class="tactical-input" name="attendance[{{ player.id }}][status]">
                                        {% for label, value in statuses %}
                                            <option value="{{ value }}" {{ selectedStatus == value ? 'selected' : '' }}>{{ label }}</option>
                                        {% endfor %}
                                    </select>
                                </td>
                                <td>
                                    <input class="tactical-input"
                                           name="attendance[{{ player.id }}][reason]"
                                           value="{{ attendance ? attendance.reason : '' }}"
                                           placeholder="Motif si absent">
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="tactical-form-actions" style="margin-top:var(--space-md);">
                <button type="submit" class="tactical-btn tactical-btn--primary">Enregistrer les présences</button>
                <a href="{{ path('app_team_calendar', {id: team.id}) }}" class="tactical-btn tactical-btn--outline">Annuler</a>
            </div>
        {% endif %}
    </form>
</div>
{% endblock %}
