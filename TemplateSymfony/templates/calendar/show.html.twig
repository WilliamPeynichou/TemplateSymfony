{% extends 'layout/app.html.twig' %}
{% block title %}Calendrier — {{ team.name }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/calendar.css') }}">
{% endblock %}

{% block content %}
{% set frMonths = ['', 'janvier', 'février', 'mars', 'avril', 'mai', 'juin', 'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'] %}
{% set monthLabel = frMonths[monthStart.format('n')] ~ ' ' ~ monthStart.format('Y') %}

<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title">Calendrier <em>{{ team.name }}</em></h1>
        <p class="tactical-page-header__sub">Matchs et entraînements de l'équipe</p>
    </div>
    <div style="display:flex;gap:0.75rem;align-items:center;">
        <a class="tactical-btn tactical-btn--primary" href="{{ path('app_training_new', {id: team.id}) }}">+ Nouvelle séance</a>
        <a class="tactical-btn tactical-btn--outline" href="{{ path('app_team_attendance_summary', {id: team.id}) }}">Synthèse présences</a>
        <a class="tactical-btn tactical-btn--outline" href="{{ path('app_team_calendar_ics', {id: team.id}) }}">Exporter ICS</a>
    </div>
</div>

<div class="tactical-page-body" style="display:flex;flex-direction:column;gap:1.25rem;">

    {# Stats présences rapides #}
    {% if attendanceTotals.total > 0 %}
    <div class="cal-stats">
        <div class="cal-stat">
            <span class="cal-stat__value cal-stat__value--lime">{{ attendanceTotals.rate }}%</span>
            <span class="cal-stat__label">Taux présences</span>
        </div>
        <div class="cal-stat">
            <span class="cal-stat__value">{{ attendanceTotals.total }}</span>
            <span class="cal-stat__label">Convocations</span>
        </div>
        <div class="cal-stat">
            <span class="cal-stat__value">{{ attendanceTotals.absent }}</span>
            <span class="cal-stat__label">Absences</span>
        </div>
        <div class="cal-stat">
            <span class="cal-stat__value">{{ attendanceTotals.excused }}</span>
            <span class="cal-stat__label">Justifiées</span>
        </div>
    </div>
    {% endif %}

    {# Toolbar du calendrier #}
    <div class="cal-toolbar">
        <div class="cal-toolbar__nav">
            <a class="cal-btn" href="{{ path('app_team_calendar', {id: team.id, month: prevMonth}) }}" aria-label="Mois précédent">‹</a>
            <a class="cal-btn cal-btn--today" href="{{ path('app_team_calendar', {id: team.id, month: currentMonth}) }}">Aujourd'hui</a>
            <a class="cal-btn" href="{{ path('app_team_calendar', {id: team.id, month: nextMonth}) }}" aria-label="Mois suivant">›</a>
        </div>
        <h2 class="cal-toolbar__title">{{ monthLabel|capitalize }}</h2>
        <div class="cal-toolbar__legend">
            <span class="cal-legend cal-legend--match"><span class="cal-legend__dot"></span>Match</span>
            <span class="cal-legend cal-legend--training"><span class="cal-legend__dot"></span>Entraînement</span>
        </div>
    </div>

    {# Grille du mois #}
    <div class="cal-grid">
        <div class="cal-grid__head">
            {% for d in ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'] %}
                <div class="cal-grid__head-cell">{{ d }}</div>
            {% endfor %}
        </div>

        {% for week in weeks %}
            <div class="cal-grid__row">
                {% for day in week %}
                    <div class="cal-day {{ day.isCurrent ? '' : 'cal-day--off' }} {{ day.isToday ? 'cal-day--today' : '' }}">
                        <div class="cal-day__num">{{ day.dayNum }}</div>
                        {% if day.events|length > 0 %}
                            <div class="cal-day__events">
                                {% for ev in day.events %}
                                    <div class="cal-event cal-event--{{ ev.type }}" title="{{ ev.title }} — {{ ev.meta }}">
                                        <a href="{{ ev.url }}" class="cal-event__main">
                                            <span class="cal-event__time">{{ ev.time }}</span>
                                            <span class="cal-event__title">{{ ev.title }}</span>
                                        </a>
                                        {% if ev.type == 'match' and ev.strategyName %}
                                            <a href="{{ ev.strategyUrl }}"
                                               class="cal-event__tactic"
                                               title="Plan tactique : {{ ev.strategyName }}{% if ev.formation %} ({{ ev.formation }}){% endif %}">
                                                ⬡ {{ ev.formation ?: ev.strategyName }}
                                            </a>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
