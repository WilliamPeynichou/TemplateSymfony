{% extends 'layout/app.html.twig' %}
{% block title %}Éditer la note — {{ note.matchLabel }}{% endblock %}

{% block content %}
<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title">Éditer la note</h1>
        <p class="tactical-page-header__sub">{{ note.matchLabel }} · {{ note.matchDate|date('d/m/Y') }}</p>
    </div>
    <a href="{{ path('app_match_note_index', {teamId: team.id}) }}" class="tactical-btn tactical-btn--outline">← Retour</a>
</div>

<div class="tactical-page-body">
    <div class="tactical-form-card" style="max-width:640px;">
        {{ form_start(form) }}
            <div class="tactical-form-group">{{ form_row(form.matchLabel) }}</div>
            <div class="tactical-form-group">{{ form_row(form.matchDate) }}</div>
            <div class="tactical-form-group">{{ form_row(form.content) }}</div>
            <div style="display:flex;gap:1rem;margin-top:1.5rem;">
                <button type="submit" class="tactical-btn tactical-btn--primary">Enregistrer</button>
                <a href="{{ path('app_match_note_index', {teamId: team.id}) }}" class="tactical-btn tactical-btn--outline">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
