{% extends 'layout/app.html.twig' %}
{% block title %}{{ strategy.name }} — Compo & tactique{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/strategy.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/composition.css') }}">
{% endblock %}

{% block javascripts %}
    {{ importmap('app') }}
    {{ importmap('strategy') }}
{% endblock %}

{% block content %}
<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title"><em>{{ strategy.name }}</em></h1>
        <p class="tactical-page-header__sub">
            {% if strategy.isFormation %}{{ strategy.formation }} · {% endif %}
            {{ strategy.isFree ? 'Composition libre' : 'Composition structurée' }}
            · dernière mise à jour {{ strategy.updatedAt|date('d/m/Y H:i') }}
        </p>
    </div>
    <div style="display:flex;gap:0.75rem;align-items:center;">
        {# Toggle mode #}
        <form method="post" action="{{ path('app_strategy_toggle_mode', {teamId: team.id, id: strategy.id}) }}"
              onsubmit="return confirm('Basculer en mode {{ strategy.isFree ? 'formation' : 'libre' }} ? Les slots seront {{ strategy.isFree ? 'réinitialisés depuis la formation ' ~ strategy.formation : 'conservés' }}.')">
            <input type="hidden" name="_token" value="{{ csrf_token('toggle_mode_' ~ strategy.id) }}">
            <button type="submit" class="tactical-btn tactical-btn--sm {{ strategy.isFree ? 'tactical-btn--outline' : 'tactical-btn--outline' }}">
                {% if strategy.isFree %}
                    ⬡ Passer en formation
                {% else %}
                    ⬡ Passer en libre
                {% endif %}
            </button>
        </form>
        <a href="{{ path('app_strategy_index', {teamId: team.id}) }}" class="tactical-btn tactical-btn--outline">← Tactiques</a>
        <span class="tactical-save-indicator" data-strategy-target="saveIndicator"></span>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="fm-flash fm-flash--success">{{ message }}</div>
{% endfor %}

<div class="tactical-page-body fm-strategy-editor"
     data-controller="strategy"
     data-strategy-mode-value="{{ strategy.mode }}"
     data-strategy-save-url-value="{{ path('app_strategy_save', {teamId: team.id, id: strategy.id}) }}"
     data-strategy-apply-url-value="{{ path('app_strategy_apply_formation', {teamId: team.id, id: strategy.id}) }}"
     data-strategy-roles-value="{{ roles|json_encode|e('html_attr') }}">

    <div class="fm-strategy-layout">

        {# ─────────── Colonne gauche ─────────── #}
        <aside class="fm-strategy-aside fm-strategy-aside--left">
            <div class="fm-field">
                <label>Nom</label>
                <input type="text" class="fm-input" value="{{ strategy.name }}"
                       data-strategy-target="name" data-action="change->strategy#markDirty">
            </div>
            <div class="fm-field">
                <label>Description</label>
                <textarea class="fm-input fm-input--area" rows="2"
                          data-strategy-target="description" data-action="change->strategy#markDirty">{{ strategy.description }}</textarea>
            </div>

            {# Formation : visible en mode formation uniquement #}
            {% if strategy.isFormation %}
            <div class="fm-field" data-strategy-formation-section>
                <label>Formation</label>
                <select class="fm-input" data-strategy-target="formation" data-action="change->strategy#changeFormation">
                    {% for key, f in formations %}
                        <option value="{{ key }}" {{ strategy.formation == key ? 'selected' : '' }}>{{ f.label }}</option>
                    {% endfor %}
                </select>
                <span class="fm-field__help">Changer la formation repositionne les slots.</span>
            </div>
            {% endif %}

            {# Instructions tactiques : mode formation uniquement (section repliable en libre) #}
            {% if strategy.isFormation %}
            <hr class="fm-divider">
            <h3 class="fm-aside__title">Instructions d'équipe</h3>

            {% set chipFields = [
                { key: 'mentality',         label: 'Mentalité',       options: constant('App\\Entity\\TacticalStrategy::MENTALITIES'),     current: strategy.mentality },
                { key: 'pressingIntensity', label: 'Pressing',        options: constant('App\\Entity\\TacticalStrategy::PRESSING'),        current: strategy.pressingIntensity },
                { key: 'defensiveLine',     label: 'Ligne défensive', options: constant('App\\Entity\\TacticalStrategy::DEFENSIVE_LINES'), current: strategy.defensiveLine },
                { key: 'buildUpStyle',      label: 'Construction',    options: constant('App\\Entity\\TacticalStrategy::BUILD_UP'),        current: strategy.buildUpStyle },
                { key: 'width',             label: 'Largeur',         options: constant('App\\Entity\\TacticalStrategy::WIDTH'),           current: strategy.width },
                { key: 'tempo',             label: 'Tempo',           options: constant('App\\Entity\\TacticalStrategy::TEMPO'),           current: strategy.tempo },
                { key: 'attackingFocus',    label: 'Focus offensif',  options: constant('App\\Entity\\TacticalStrategy::ATTACKING_FOCUS'), current: strategy.attackingFocus }
            ] %}
            {% for f in chipFields %}
                <div class="fm-field">
                    <label>{{ f.label }}</label>
                    <div class="fm-chip-row">
                        {% for label, value in f.options %}
                            <button type="button"
                                    class="fm-chip {{ f.current == value ? 'fm-chip--active' : '' }}"
                                    data-field="{{ f.key }}"
                                    data-value="{{ value }}"
                                    data-action="click->strategy#pickChip">
                                {{ label }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}

            <hr class="fm-divider">
            <h3 class="fm-aside__title">Notes tactiques</h3>
            <div class="fm-field">
                <label>En possession</label>
                <textarea class="fm-input fm-input--area" rows="3" placeholder="Construction, circulation, temps forts…"
                          data-strategy-target="inPossessionNotes" data-action="change->strategy#markDirty">{{ strategy.inPossessionNotes }}</textarea>
            </div>
            <div class="fm-field">
                <label>Sans ballon</label>
                <textarea class="fm-input fm-input--area" rows="3" placeholder="Pressing, couverture, replis…"
                          data-strategy-target="outOfPossessionNotes" data-action="change->strategy#markDirty">{{ strategy.outOfPossessionNotes }}</textarea>
            </div>
            <div class="fm-field">
                <label>Transitions</label>
                <textarea class="fm-input fm-input--area" rows="2" placeholder="Après récupération / après perte…"
                          data-strategy-target="transitionNotes" data-action="change->strategy#markDirty">{{ strategy.transitionNotes }}</textarea>
            </div>
            <div class="fm-field">
                <label>Coups de pied arrêtés</label>
                <textarea class="fm-input fm-input--area" rows="2" placeholder="Corners, coups francs, penalty…"
                          data-strategy-target="setPieceNotes" data-action="change->strategy#markDirty">{{ strategy.setPieceNotes }}</textarea>
            </div>

            {% else %}
            {# Mode libre : notes globales simplifiées #}
            <hr class="fm-divider">
            <h3 class="fm-aside__title">Notes du plan</h3>
            <div class="fm-field">
                <label>Notes générales</label>
                <textarea class="fm-input fm-input--area" rows="6" placeholder="Objectifs, consignes, idées tactiques…"
                          data-strategy-target="inPossessionNotes" data-action="change->strategy#markDirty">{{ strategy.inPossessionNotes }}</textarea>
            </div>
            {% endif %}

            {# Targets masqués pour la compatibilité JS en mode libre #}
            {% if strategy.isFree %}
                <textarea style="display:none" data-strategy-target="description"></textarea>
                <textarea style="display:none" data-strategy-target="outOfPossessionNotes"></textarea>
                <textarea style="display:none" data-strategy-target="transitionNotes"></textarea>
                <textarea style="display:none" data-strategy-target="setPieceNotes"></textarea>
                <select style="display:none" data-strategy-target="formation"><option value="{{ strategy.formation }}" selected>{{ strategy.formation }}</option></select>
            {% endif %}
        </aside>

        {# ─────────── Centre : terrain ─────────── #}
        <section class="fm-strategy-center">
            <div class="fm-pitch-wrap">
                <svg class="fm-pitch-svg" viewBox="0 0 68 105" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <defs>
                        <linearGradient id="pitchStripe" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#101415"/>
                            <stop offset="100%" stop-color="#161b1c"/>
                        </linearGradient>
                    </defs>

                    <rect width="68" height="105" fill="url(#pitchStripe)"/>
                    {% for i in 0..6 %}
                        <rect x="0" y="{{ i * 15 }}" width="68" height="7.5" fill="{{ i % 2 == 0 ? '#101415' : '#141919' }}" opacity="{{ i % 2 == 0 ? 1 : 0.9 }}"/>
                    {% endfor %}

                    <g fill="none" stroke="rgba(199,243,0,0.42)" stroke-width="0.55" vector-effect="non-scaling-stroke" shape-rendering="geometricPrecision">
                        <rect x="1" y="1" width="66" height="103"/>
                        <line x1="1" y1="52.5" x2="67" y2="52.5"/>
                        <circle cx="34" cy="52.5" r="9.2"/>
                        <rect x="13.84" y="1" width="40.32" height="16.5"/>
                        <rect x="13.84" y="87.5" width="40.32" height="16.5"/>
                        <rect x="24.84" y="1" width="18.32" height="5.5"/>
                        <rect x="24.84" y="98.5" width="18.32" height="5.5"/>
                    </g>

                    <g fill="rgba(199,243,0,0.85)">
                        <circle cx="34" cy="52.5" r="0.72"/>
                        <circle cx="34" cy="12.2" r="0.55"/>
                        <circle cx="34" cy="92.8" r="0.55"/>
                    </g>
                </svg>
                <div class="fm-pitch-slots {{ strategy.isFree ? 'fm-pitch-slots--free' : '' }}"
                     data-strategy-target="pitch">
                    {% for slot in strategy.slots %}
                        {% set player = slot.player %}
                        {% set suggested = null %}
                        {% if strategy.isFormation %}
                            {% for s in suggestions %}
                                {% if s.slot == slot.slotIndex %}{% set suggested = s.suggestedPlayer %}{% endif %}
                            {% endfor %}
                        {% endif %}
                        <div class="fm-pitch-slot fm-pitch-slot--{{ slot.positionGroup|lower }}"
                             data-strategy-target="slot"
                             data-slot-index="{{ slot.slotIndex }}"
                             data-position-code="{{ slot.positionCode }}"
                             data-position-group="{{ slot.positionGroup }}"
                             data-role="{{ slot.role }}"
                             data-duty="{{ slot.duty }}"
                             data-label="{{ slot.label }}"
                             data-player-id="{{ player ? player.id : '' }}"
                             data-instructions="{{ slot.individualInstructions }}"
                             data-suggested-id="{{ suggested ? suggested.id : '' }}"
                             data-suggested-name="{{ suggested ? suggested.fullName : '' }}"
                             data-suggested-score="{{ suggested ? suggested.suitability : '' }}"
                             style="left:{{ slot.posX }}%;top:{{ slot.posY }}%"
                             data-action="click->strategy#selectSlot">
                            <div class="fm-pitch-slot__token">
                                <span class="fm-pitch-slot__num">{% if player %}{{ player.number }}{% else %}{{ slot.label }}{% endif %}</span>
                            </div>
                            <div class="fm-pitch-slot__name">
                                {% if player %}{{ player.lastName }}{% else %}<em>{{ strategy.isFree ? '?' : '— libre —' }}</em>{% endif %}
                            </div>
                            {% if strategy.isFormation %}
                            <div class="fm-pitch-slot__role">{{ slot.role|replace({'_':' '}) }} · <span class="fm-duty fm-duty--{{ slot.duty }}">{{ slot.dutyLabel }}</span></div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
            <div class="fm-pitch-foot">
                {% if strategy.isFree %}
                    <button type="button" class="tactical-btn tactical-btn--danger"
                            data-strategy-target="removeSlotBtn"
                            data-action="click->strategy#removeSelectedSlot" style="display:none">
                        Retirer le slot
                    </button>
                {% else %}
                    <button type="button" class="tactical-btn tactical-btn--outline"
                            data-action="click->strategy#autoAssign">Auto-composer (meilleur XI)</button>
                {% endif %}
                <button type="button" class="tactical-btn tactical-btn--primary"
                        data-action="click->strategy#save">Sauvegarder</button>
            </div>
        </section>

        {# ─────────── Colonne droite : inspecteur ─────────── #}
        <aside class="fm-strategy-aside fm-strategy-aside--right">
            <div class="fm-inspector" data-strategy-target="inspector" hidden>
                <header class="fm-inspector__head">
                    <strong data-strategy-target="inspectorLabel">Slot</strong>
                    <button type="button" class="fm-inspector__close" data-action="click->strategy#closeInspector">×</button>
                </header>

                <div class="fm-field">
                    <label>Joueur assigné</label>
                    {% if strategy.isFree %}
                        <div class="fm-selected-player" data-strategy-target="selectedPlayerCard">
                            <span class="fm-selected-player__empty">Aucun joueur affecté</span>
                        </div>
                        <input type="hidden" data-strategy-target="inspectorPlayer" value="">
                        <button type="button" class="tactical-btn tactical-btn--sm tactical-btn--outline"
                                data-action="click->strategy#clearPlayer">
                            Libérer le slot
                        </button>
                    {% else %}
                        <select class="fm-input" data-strategy-target="inspectorPlayer" data-action="change->strategy#updatePlayer">
                            <option value="">— Libre —</option>
                            {% for p in players %}
                                <option value="{{ p.id }}" data-position-group="{{ p.positionGroup }}" data-position="{{ p.position }}">
                                    #{{ p.number }} {{ p.fullName }} ({{ p.position }})
                                </option>
                            {% endfor %}
                        </select>
                        <div style="display:none" data-strategy-target="selectedPlayerCard"></div>
                    {% endif %}
                    {% if strategy.isFormation %}
                    <div class="fm-suggestion" data-strategy-target="suggestion" hidden>
                        Suggestion : <strong data-strategy-target="suggestionName"></strong>
                        · <span data-strategy-target="suggestionScore"></span>%
                        <button type="button" class="fm-suggestion__apply" data-action="click->strategy#applySuggestion">Appliquer</button>
                    </div>
                    {% else %}
                        <div data-strategy-target="suggestion" hidden></div>
                    {% endif %}
                </div>

                <div class="fm-field">
                    <label>Note / instructions</label>
                    <textarea class="fm-input fm-input--area" rows="4"
                              placeholder="{% if strategy.isFree %}Notes libres sur ce joueur…{% else %}Instructions individuelles…{% endif %}"
                              data-strategy-target="inspectorInstructions"
                              data-action="change->strategy#updateInstructions"></textarea>
                </div>

                {% if strategy.isFormation %}
                <div class="fm-field">
                    <label>Rôle</label>
                    <select class="fm-input" data-strategy-target="inspectorRole" data-action="change->strategy#updateRole"></select>
                </div>
                <div class="fm-field">
                    <label>Devoir</label>
                    <div class="fm-chip-row">
                        {% for label, value in constant('App\\Entity\\FormationSlot::DUTIES') %}
                            <button type="button"
                                    class="fm-chip fm-duty fm-duty--{{ value }}"
                                    data-strategy-target="dutyBtn"
                                    data-value="{{ value }}"
                                    data-action="click->strategy#updateDuty">
                                {{ label }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
                {% else %}
                    {# Targets masqués pour compatibilité JS #}
                    <select style="display:none" data-strategy-target="inspectorRole"></select>
                    <button style="display:none" data-strategy-target="dutyBtn" data-value="support"></button>
                {% endif %}
            </div>

            <div class="fm-inspector-empty" data-strategy-target="inspectorEmpty">
                {% if strategy.isFree %}
                {% else %}
                    <p>Cliquez un slot sur le terrain pour éditer son rôle, son devoir et le joueur affecté.</p>
                    <p class="fm-inspector-empty__hint">Utilisez <strong>Auto-composer</strong> pour laisser le système suggérer le meilleur XI.</p>
                {% endif %}
            </div>

            {% if strategy.isFree %}
                <hr class="fm-divider">
                <div class="fm-roster fm-roster--full">
                    <div class="fm-roster__head">
                        <strong>Effectif utilisé</strong>
                        <span>{{ players|length }} joueur{{ players|length > 1 ? 's' : '' }} · équipe {{ team.name }}</span>
                    </div>
                    <div class="fm-roster__filters">
                        <button type="button" class="fm-roster__filter fm-roster__filter--active"
                                data-strategy-target="rosterFilter"
                                data-filter="all"
                                data-action="click->strategy#filterRoster">
                            Tous
                        </button>
                        <button type="button" class="fm-roster__filter"
                                data-strategy-target="rosterFilter"
                                data-filter="GK"
                                data-action="click->strategy#filterRoster">
                            GK
                        </button>
                        <button type="button" class="fm-roster__filter"
                                data-strategy-target="rosterFilter"
                                data-filter="DEF"
                                data-action="click->strategy#filterRoster">
                            Déf
                        </button>
                        <button type="button" class="fm-roster__filter"
                                data-strategy-target="rosterFilter"
                                data-filter="MID"
                                data-action="click->strategy#filterRoster">
                            Mil
                        </button>
                        <button type="button" class="fm-roster__filter"
                                data-strategy-target="rosterFilter"
                                data-filter="ATT"
                                data-action="click->strategy#filterRoster">
                            Att
                        </button>
                    </div>
                    <div class="fm-roster__list">
                        {% for p in players %}
                            <button type="button"
                                    class="fm-roster__item"
                                    data-strategy-target="rosterPlayer"
                                    data-action="click->strategy#pickRosterPlayer"
                                    data-player-id="{{ p.id }}"
                                    data-player-name="{{ p.fullName }}"
                                    data-player-last-name="{{ p.lastName }}"
                                    data-player-number="{{ p.number }}"
                                    data-player-position="{{ p.position }}"
                                    data-player-group="{{ p.positionGroup }}"
                                    data-filter-group="{{ p.positionGroup }}"
                                    draggable="true">
                                <div class="fm-roster__main">
                                    <span class="fm-roster__number">#{{ p.number }}</span>
                                    <span class="fm-roster__name">{{ p.fullName }}</span>
                                </div>
                                <div class="fm-roster__meta">
                                    <span class="fm-roster__badge fm-roster__badge--{{ p.positionGroup|lower }}">{{ p.position }}</span>
                                    {% if p.statusLabel is defined %}
                                        <span class="fm-roster__status">{{ p.statusLabel }}</span>
                                    {% endif %}
                                </div>
                            </button>
                        {% else %}
                            <p class="fm-roster__empty">Aucun joueur dans l’équipe sélectionnée.</p>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </aside>
    </div>
</div>
{% endblock %}
