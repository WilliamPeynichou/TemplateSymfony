{% extends 'layout/app.html.twig' %}
{% block title %}Compo & tactiques — {{ team.name }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/strategy.css') }}">
{% endblock %}

{% block content %}
<div class="tactical-page-header">
    <div>
        <h1 class="tactical-page-header__title">Compo & tactiques <em>{{ team.name }}</em></h1>
        <p class="tactical-page-header__sub">Gestion de composition et tactiques réutilisables pour les matchs. {{ strategies|length }} tactique{{ strategies|length > 1 ? 's' : '' }}</p>
    </div>
</div>

<div class="tactical-page-body">

    <div class="tactical-card" style="margin-bottom:1rem;padding:1rem 1.25rem;">
        <div style="margin-bottom:0.75rem;">
            <strong style="display:block;font-size:0.95rem;margin-bottom:0.25rem;">Nouvelle tactique (plan libre)</strong>
            <span style="font-size:0.8125rem;color:var(--on-surface-variant);">Terrain vide : placez les joueurs et les consignes comme vous voulez. Vous pourrez passer en mode formation depuis l’éditeur si besoin.</span>
        </div>
        <form method="post" action="{{ path('app_strategy_new', {teamId: team.id}) }}" style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
            <input type="hidden" name="mode" value="free">
            <input type="text" name="name" class="tactical-input" placeholder="Nom (optionnel)" style="flex:1;min-width:200px;">
            <button type="submit" class="tactical-btn tactical-btn--primary">Créer</button>
        </form>
    </div>

    {# ── Liste plans ── #}
    {% if strategies|length == 0 %}
        <div class="tactical-card tactical-card--empty">
            <p>Aucune tactique. Créez votre première composition tactique ci-dessus.</p>
        </div>
    {% else %}
        <div class="fm-strategy-grid">
            {% for s in strategies %}
                <article class="fm-strategy-card {{ s.isDefault ? 'fm-strategy-card--default' : '' }}">
                    <header class="fm-strategy-card__head">
                        <div>
                            <div class="fm-strategy-card__name">{{ s.name }}</div>
                            <div class="fm-strategy-card__formation">
                                {% if s.isFormation %}
                                    {{ s.formation }} · {{ s.labelFor('mentality') }}
                                {% else %}
                                    Plan libre
                                {% endif %}
                            </div>
                        </div>
                        <div style="display:flex;gap:0.4rem;align-items:center;">
                            {% if s.isFree %}
                                <span class="tactical-badge" style="background:rgba(199,243,0,0.15);color:var(--secondary-container);">Libre</span>
                            {% else %}
                                <span class="tactical-badge" style="background:rgba(255,255,255,0.06);color:var(--on-surface-variant);">Formation</span>
                            {% endif %}
                            {% if s.isDefault %}
                                <span class="tactical-badge tactical-badge--lime">Par défaut</span>
                            {% endif %}
                        </div>
                    </header>

                    {% if s.isFormation %}
                    <div class="fm-strategy-card__pitch">
                        <div class="fm-strategy-card__pitch-bg"></div>
                        {% for slot in s.slots %}
                            <div class="fm-strategy-card__dot fm-strategy-card__dot--{{ slot.positionGroup|lower }}"
                                 style="left:{{ slot.posX }}%;top:{{ slot.posY }}%"></div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="fm-strategy-card__pitch fm-strategy-card__pitch--free">
                        <div class="fm-strategy-card__pitch-bg"></div>
                        {% for slot in s.slots %}
                            {% if slot.player %}
                            <div class="fm-strategy-card__dot fm-strategy-card__dot--{{ slot.positionGroup|lower }}"
                                 style="left:{{ slot.posX }}%;top:{{ slot.posY }}%"
                                 title="{{ slot.player.lastName }}">{{ slot.player.number }}</div>
                            {% else %}
                            <div class="fm-strategy-card__dot" style="left:{{ slot.posX }}%;top:{{ slot.posY }}%;opacity:0.35;"></div>
                            {% endif %}
                        {% endfor %}
                        {% if s.slots|length == 0 %}
                            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
                                <span style="font-size:11px;color:var(--on-surface-variant);opacity:0.5;">Canvas vide</span>
                            </div>
                        {% endif %}
                    </div>
                    {% endif %}

                    <footer class="fm-strategy-card__foot">
                        <a href="{{ path('app_strategy_edit', {teamId: team.id, id: s.id}) }}"
                           class="tactical-btn tactical-btn--sm tactical-btn--primary">Éditer</a>

                        <form method="post" action="{{ path('app_strategy_clone', {teamId: team.id, id: s.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('clone_strategy_' ~ s.id) }}">
                            <button type="submit" class="tactical-btn tactical-btn--sm tactical-btn--outline">Dupliquer</button>
                        </form>

                        {% if not s.isDefault %}
                            <form method="post" action="{{ path('app_strategy_set_default', {teamId: team.id, id: s.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('default_strategy_' ~ s.id) }}">
                                <button type="submit" class="tactical-btn tactical-btn--sm tactical-btn--outline">Par défaut</button>
                            </form>
                        {% endif %}

                        <form method="post" action="{{ path('app_strategy_delete', {teamId: team.id, id: s.id}) }}"
                              onsubmit="return confirm('Supprimer « {{ s.name }} » ?')" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_strategy_' ~ s.id) }}">
                            <button type="submit" class="tactical-btn tactical-btn--sm tactical-btn--danger">Supprimer</button>
                        </form>
                    </footer>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
