# Andfield — exemple de configuration d'environnement
# Copier ce fichier en .env.local et remplir les secrets.
# Génération rapide : `make secrets`

###> locale ###
APP_LOCALE=fr
###< locale ###

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_with_openssl_rand_hex_16
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# En local (hors docker) : mysql://app:Andfield@127.0.0.1:3306/bddAndfield
# Dans docker compose : mysql://app:Andfield@database:3306/bddAndfield
DATABASE_URL="mysql://app:Andfield@127.0.0.1:3306/bddAndfield?serverVersion=8.0&charset=utf8mb4"
MYSQL_DATABASE=bddAndfield
MYSQL_USER=app
MYSQL_PASSWORD=Andfield
MYSQL_ROOT_PASSWORD=Andfield
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# En dev : Mailpit (UI http://localhost:8025). En prod : smtp://user:pass@host:port
MAILER_DSN=smtp://mailpit:1025
APP_FROM_EMAIL=no-reply@andfield.local
###< symfony/mailer ###

###> agent ia ###
# Secrets : `openssl rand -hex 32` pour chacun.
# AGENT_SECRET        : token envoyé par l'agent Python vers Symfony (Authorization Bearer agent:<secret>).
# AGENT_INTERNAL_SECRET : token envoyé par Symfony vers l'agent FastAPI (X-Agent-Internal-Secret).
AGENT_SECRET=change_me
AGENT_INTERNAL_SECRET=change_me

# URL agent interne (utilisée par Symfony pour joindre FastAPI)
AGENT_BASE_URL=http://agent:8001

# URL Symfony vue depuis l'agent (utilisée par FastAPI pour appeler les API CRUD)
SYMFONY_API_URL=http://php/api/v1

# Modèle LLM (Ollama par défaut)
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=qwen3:1.7b

# RAG (recherche sémantique sur les notes de match)
# EMBEDDINGS_BACKEND : 'ollama' (local, gratuit) ou 'openai' (payant, meilleur)
EMBEDDINGS_BACKEND=ollama
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text
# Si EMBEDDINGS_BACKEND=openai :
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
###< agent ia ###

###> stripe (phase 2) ###
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
###< stripe ###

###> sentry (phase 4) ###
SENTRY_DSN=
###< sentry ###
